model sgs_administration_epreuve {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  epreuve_id          String            @db.Uuid
  salle_classe_id     String?           @db.Uuid
  administration_date DateTime          @db.Date
  administrated_as    String?           @db.VarChar(2)
  max_grade_points    Decimal           @db.Decimal(4, 2)
  notes               String?           @db.VarChar(256)
  create_date         DateTime          @db.Timestamptz(6)
  created_by          String            @db.VarChar(64)
  change_date         DateTime?         @db.Timestamptz(6)
  changed_by          String?           @db.VarChar(64)
  lkp_exam_type       lkp_exam_type?    @relation(fields: [administrated_as], references: [code], onDelete: NoAction, onUpdate: NoAction)
  sgs_matiere         sgs_matiere       @relation(fields: [epreuve_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sgs_salle_classe    sgs_salle_classe? @relation(fields: [salle_classe_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
