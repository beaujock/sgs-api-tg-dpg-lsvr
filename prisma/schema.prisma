generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model lkp_absence_reason {
  code          String         @id @db.VarChar(2)
  display_value String
  description   String?
  sgs_presence  sgs_presence[]
}

model lkp_attendance_status {
  code          String         @id @db.VarChar(2)
  display_value String
  description   String?
