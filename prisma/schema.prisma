model sgs_user_access {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_permission_id  String              @db.Uuid
  resource_id         String              @db.Uuid
  user_id             String              @db.Uuid
  status              String              @default("A") @db.VarChar(2)
